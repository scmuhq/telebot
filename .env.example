# Token du bot Telegram (obtenu via @BotFather)
BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz

# ID du groupe principal (nombre négatif, ex: -1001234567890)
MAIN_GROUP_ID=-1001234567890

# ID du groupe backup (nombre négatif, ex: -1001234567891)
BACKUP_GROUP_ID=-1001234567891

# ID(s) des administrateurs/fondateurs (séparés par des virgules)
ADMIN_IDS=123456789,987654321

# Nom du canal (affiché dans les messages)
CHANNEL_NAME=MonCanal

# Durée du CAPTCHA en secondes (par défaut 60)
CAPTCHA_TIMEOUT=60

# Durée du ban temporaire pour mots interdits (en secondes, 3600 = 1h)
TEMP_BAN_DURATION=3600
